{
  "extends": "../expo-module-scripts/tsconfig.node",
  "include": ["./src"],
  "exclude": ["**/__mocks__/*", "**/__tests__/*"],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "declaration": true,
    "inlineSources": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  }
}
